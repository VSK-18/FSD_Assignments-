<%- include('partials/header') %>

    <section class="hero-section">
        <div class="hero-content">
            <h1 class="fade-in-up">Experience Modern Dental Care</h1>
            <p class="fade-in-up delay-1">Premium dental services with state-of-the-art technology and compassionate
                care.</p>
            <div class="hero-buttons fade-in-up delay-2">
                <a href="/book" class="btn btn-primary">Book Now</a>
                <a href="#services" class="btn btn-secondary">Our Services</a>
            </div>
        </div>
        <div class="hero-image fade-in">
            <div class="glass-card flex-center">
                <div class="animated-tooth">✨🦷✨</div>
            </div>
        </div>
    </section>

    <section id="services" class="services">
        <h2 class="fade-in">Exceptional Services</h2>
        <div class="service-cards">
            <div class="card hover-up">
                <h3>General Dentistry</h3>
                <p>Comprehensive care to keep your smile healthy and bright.</p>
            </div>
            <div class="card hover-up">
                <h3>Orthodontics</h3>
                <p>Aligners and braces for perfectly straight teeth.</p>
            </div>
            <div class="card hover-up">
                <h3>Cosmetic</h3>
                <p>Veneers and whitening for your perfect smile.</p>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>